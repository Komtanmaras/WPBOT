# DeepSeek API Anahtari (platform.deepseek.com adresinden al)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Hedef grup adi (WhatsApp'ta gorundugu gibi, buyuk/kucuk harf onemsiz)
TARGET_GROUP_NAME=Grup Adi

# Alternatif: Grup ID (bot baslayinca listede gorunur, orn: 120363123456789012@g.us)
# TARGET_GROUP_ID=

# DEBUG=true yapinca gelen grup mesajlarinin detayini loglar
DEBUG=false

# Taklit edilecek kisi adi (grupta bu isimle seslenilirse cevap verir)
USER_NAME=Ahmet

# Ek isim varyantlari (virgulle), orn: Maras,maraş
# USER_NAME_ALIASES=

# Kullanilacak DeepSeek modeli (varsayilan: deepseek-v4-flash)
DEEPSEEK_MODEL=deepseek-v4-flash

# Minimum gecikme (milisaniye) - varsayilan 15000 (15 saniye)
MIN_DELAY_MS=15000

# Maksimum gecikme normal mod (milisaniye) - 120000 = 2 dk test, 600000 = 10 dk
MAX_DELAY_MS=120000

# Hizli muhabbet (son cevabindan 2 dk icinde sana yanit gelirse)
FAST_REPLY_WINDOW_MS=120000
MIN_FAST_DELAY_MS=10000
MAX_FAST_DELAY_MS=45000

# Son kac mesaj saklanir
HISTORY_SIZE=15
# Bottan sonra kac mesaj beklenir (1 = daha sik katilir)
MIN_MESSAGES_BEFORE_OPTIONAL=1

# Ard arda gelen mesajlari birlestir (ms) - orn Maraş + Nasılsın
MESSAGE_DEBOUNCE_MS=3500

# Katilim kararinda okunacak mesaj sayisi
DECISION_CONTEXT_SIZE=10

# Cevap uretiminde okunacak mesaj sayisi
REPLY_CONTEXT_SIZE=15

# AI token limitleri
# Ust sinir; gercek maliyet = uretilen token (prompt kisa cevap istiyor)
DECISION_MAX_TOKENS=64
REPLY_MAX_TOKENS=1024

# Bos cevap gelirse thinking kapali bu modelle tekrar dener
DEEPSEEK_NON_THINKING_MODEL=deepseek-chat
REPLY_MAX_CHARS=280

# Sicaklik (0-1)
DECISION_TEMPERATURE=0.35
REPLY_TEMPERATURE=0.9

# Kisilik notlari (istege bagli, prompta eklenir)
# PERSONALITY_NOTES=biraz tembel, gece uyku modunda, kisa cevap verir

# Grup uyeleri ozel bilgileri: data/personas.json (telefon + saka notlari)
