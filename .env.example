# =============================================================================
# WPBOT - Ornek ortam dosyasi
# Kopyala: cp .env.example .env  (Windows: copy .env.example .env)
# =============================================================================

# --- DeepSeek API ---
# Anahtar: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Ana model (deepseek-v4-flash onerilir)
DEEPSEEK_MODEL=deepseek-v4-flash

# Thinking modu cevabi bos birakirsa bu modelle tekrar dener
DEEPSEEK_NON_THINKING_MODEL=deepseek-chat

# --- WhatsApp hedef grup ---
# Grup adi (buyuk/kucuk harf onemsiz)
TARGET_GROUP_NAME=Grup Adi

# Grup ID (bot baslayinca terminalde listelenir; ad eslesmezse bunu kullan)
# TARGET_GROUP_ID=120363123456789012@g.us

# --- Bot kimligi ---
# Taklit edilecek kisi; adinla veya @etiket ile zorunlu cevap
USER_NAME=Maraş

# Ek isim varyantlari (virgulle)
USER_NAME_ALIASES=Maraş,Maras,maraş

# Senin kisilik notlarin (istege bagli, AI promptuna eklenir)
# PERSONALITY_NOTES=gece uyku modunda, kisa cevap verir, biraz tembel

# Grup uyeleri ozel bilgi / saka: data/personas.json (telefon + hint)

# --- Gecikme (milisaniye) ---
# Normal mod: rastgele bekleme araligi
MIN_DELAY_MS=15000
MAX_DELAY_MS=120000

# Hizli mod: sen yazdiktan sonra 2 dk icinde yanit gelirse, 10sn - 1dk arasi don
FAST_REPLY_WINDOW_MS=120000
MIN_FAST_DELAY_MS=10000
MAX_FAST_DELAY_MS=60000

# --- Mesaj isleme ---
# Ard arda gelen mesajlari birlestir (orn. "Maraş" + "Nasılsın")
MESSAGE_DEBOUNCE_MS=3500

# Bottan sonra kac baska mesaj gelmeden tekrar katilim dusunulmesin (1 = daha sik)
MIN_MESSAGES_BEFORE_OPTIONAL=1

# Gecmis: dosyada saklanan max mesaj / AI baglami
HISTORY_SIZE=15
DECISION_CONTEXT_SIZE=10
REPLY_CONTEXT_SIZE=15

# --- DeepSeek token / sicaklik ---
# max_tokens = ust sinir; ucret = gercekte uretilen token (kisa cevap = dusuk maliyet)
DECISION_MAX_TOKENS=64
REPLY_MAX_TOKENS=1024

# WhatsApp'ta gosterilecek max karakter (AI cevabi kesilir)
REPLY_MAX_CHARS=280

DECISION_TEMPERATURE=0.35
REPLY_TEMPERATURE=0.9

# --- Baslangic modu (pm2 restart / guncelleme sonrasi) ---
# idle       = sadece yeni mesajlari dinle (varsayilan)
# sync       = son mesajlari gecmise yaz, cevap verme
# reply_last = son gelen mesaji oku ve normal kurallarla cevapla
STARTUP_MODE=idle

# reply_last: bu sureden eski son mesaja cevap verme (ms, varsayilan 10 dk)
STARTUP_MAX_AGE_MS=600000

# Acilista kac mesaj cekilsin (varsayilan HISTORY_SIZE ile ayni)
# STARTUP_FETCH_LIMIT=15

# --- Hata ayiklama ---
# false: operasyonel loglar (MESAJ, PLAN, CEVAP, ATLANDI) her zaman gorunur
# true:  ek olarak AI karari, cache, iptal detaylari
DEBUG=false
